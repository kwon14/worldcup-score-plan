NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (서버 전용)
# Firebase Console > Project settings > Service accounts 에서 키를 발급해 입력하세요.
# PRIVATE_KEY는 줄바꿈을 \n 형태로 넣습니다.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# 인증 방식
# 최초 가입: 이름/사번/전화번호/비밀번호 → 서버 allowlist 검증 → Firebase Custom Token
# 이후 로그인: 사번/비밀번호 → Firebase Custom Token

# API-Football (api-sports.io) — 선택 사항: 실시간 라인업·득점·카드 데이터
# B안 운영 기준: 기본은 네이버/구글/중계 앱을 사람이 확인하고 관리자 화면에서 Firebase에 수동 입력합니다.
# 공식 API 자동 연동을 쓰지 않을 경우 FOOTBALL_API_KEY는 비워두세요. 앱은 Firebase 수동 입력 데이터로 동작합니다.
# 자동 연동을 켤 때만 아래 절차로 키를 발급해 입력하세요.
# ① https://dashboard.api-football.com/register 에서 무료 가입
# ② 로그인 후 Dashboard 상단 "API Key" 복사 → 아래에 붙여넣기
# ※ BallDontLie 키가 아닌 api-sports.io 키를 사용해야 합니다
# ※ 무료 100 req/day 기준으로는 5분 이상 캐시 + 수동 입력 fallback 운영을 권장합니다.
FOOTBALL_API_KEY=

# 공식 API 호출량 조정 (B안 무료/수동 운영 기본값)
# - FOOTBALL_LIVE_CACHE_SECONDS: 스코어/상태/이벤트 서버 캐시 TTL, 기본 300초
# - FOOTBALL_LINEUP_CACHE_SECONDS: 라인업 서버 캐시 TTL, 기본 1800초
# - NEXT_PUBLIC_LIVE_POLL_INTERVAL_SECONDS: 브라우저 polling 간격, 기본 60초, 최소 10초
FOOTBALL_LIVE_CACHE_SECONDS=300
FOOTBALL_LINEUP_CACHE_SECONDS=1800
NEXT_PUBLIC_LIVE_POLL_INTERVAL_SECONDS=60

# API-Football fixture ID를 알고 있으면 설정하세요.
# 설정 시 앱이 2026 월드컵 일정 검색을 건너뛰고 해당 fixture를 바로 조회합니다.
# matchId=2(멕시코전): FOOTBALL_FIXTURE_ID_M2=123456
# matchId=1(체코전): FOOTBALL_FIXTURE_ID_M1=123457
FOOTBALL_FIXTURE_ID_M2=
FOOTBALL_FIXTURE_ID_M1=
